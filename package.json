{
	"name": "moxfield-api",
	"version": "1.0.3",
	"description": "A Javascript library for https://moxfield.com written in Typescript.",
	"keywords": [
		"deck",
		"moxfield",
		"api"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/MarioMH8/moxfield-api.git"
	},
	"homepage": "https://github.com/MarioMH8/moxfield-api",
	"bugs": {
		"url": "https://github.com/MarioMH8/moxfield-api/issues"
	},
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"files": [
		"dist"
	],
	"main": "./dist/moxfield-api.mjs",
	"types": "./dist/moxfield-api.d.mts",
	"exports": {
		".": {
			"import": "./dist/moxfield-api.d.mts"
		}
	},
	"scripts": {
		"build": "tsdown",
		"lint": "eslint .",
		"lint:fix": "eslint --fix .",
		"prepublishOnly": "tsdown",
		"test": "bun test",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"zod": "^4.0.2",
		"zod-fetch": "^0.1.1"
	},
	"devDependencies": {
		"@changesets/cli": "2.31.0",
		"@hexadrop/eslint-config": "1.0.5",
		"@hexadrop/tsconfig": "0.0.5",
		"@types/bun": "1.3.14",
		"eslint": "10.6.0",
		"tsdown": "0.22.3",
		"typescript": "6.0.3"
	}
}
