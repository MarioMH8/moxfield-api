{
	"name": "moxfield-api",
	"version": "2.0.0",
	"description": "A Javascript library for https://moxfield.com written in Typescript.",
	"keywords": [
		"deck",
		"moxfield",
		"api"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/MarioMH8/moxfield-api.git"
	},
	"homepage": "https://github.com/MarioMH8/moxfield-api",
	"bugs": {
		"url": "https://github.com/MarioMH8/moxfield-api/issues"
	},
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"files": [
		"dist"
	],
	"main": "./dist/moxfield-api.mjs",
	"types": "./dist/moxfield-api.d.mts",
	"exports": {
		".": {
			"import": "./dist/moxfield-api.d.mts"
		}
	},
	"scripts": {
		"build": "tsdown",
		"commitlint": "commitlint --edit",
		"lint": "eslint --cache .",
		"lint:ci": "eslint --cache --cache-strategy content .",
		"lint:fix": "eslint --cache --fix .",
		"prepare": "husky",
		"prepublishOnly": "tsdown",
		"test": "bun test",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"moxfield-api": "^2.0.0",
		"zod": "^4.0.2",
		"zod-fetch": "^0.1.1"
	},
	"devDependencies": {
		"@changesets/cli": "2.31.1",
		"@commitlint/cli": "21.2.1",
		"@commitlint/config-conventional": "21.2.0",
		"@hexadrop/eslint-config": "1.0.6",
		"@hexadrop/tsconfig": "0.0.5",
		"@types/bun": "1.3.14",
		"eslint": "10.7.0",
		"husky": "9.1.7",
		"lint-staged": "17.0.8",
		"tsdown": "0.22.9",
		"typescript": "6.0.3"
	}
}
